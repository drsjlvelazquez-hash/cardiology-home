# Local dev / desktop-file builds only: the browser calls the Anthropic API
# directly with this key. Get one at https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=

# NOTE: the deployed Cloudflare site does NOT use this key for AI. Set
# ANTHROPIC_API_KEY as a Secret in the Cloudflare dashboard instead (see README).

# ─── Supabase (shared patient database) ──────────────────────────────────────
# When BOTH are set, patients are stored in Supabase (shared across devices);
# leave them blank to fall back to per-device localStorage.
# Find these in the Supabase dashboard → Project Settings → API.
# The anon key is safe to expose in the browser (Row Level Security governs access).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
